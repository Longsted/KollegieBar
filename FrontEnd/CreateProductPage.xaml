<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrontEnd.CreateProductPage"
             Title="Create product">
       
       <ScrollView>
           <VerticalStackLayout Padding="20">

               <Entry x:Name="NameEntry"
                      Placeholder="Navn" />

               <Entry x:Name="CostPriceEntry"
                      Placeholder="Kostpris"
                      Keyboard="Numeric" />

               <Entry x:Name="StockQuantityEntry"
                      Placeholder="Lagerantal"
                      Keyboard="Numeric" />

               <Entry x:Name="VolumeClEntry"
                      Placeholder="Volumen i cl"
                      Keyboard="Numeric" />

               <Entry x:Name="SalesPriceEntry"
                      Placeholder="Salgspris"
                      Keyboard="Numeric" />

               <Entry x:Name="AlcoholPercentageEntry"
                      Placeholder="Alkoholprocent"
                      Keyboard="Numeric" />

               <Button Text="Opret produkt"
                       Clicked="OnCreateProduct_Clicked" />

               <Label x:Name="ResultLabel" />

           </VerticalStackLayout>
       </ScrollView>
</ContentPage>

