<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrontEnd.CreateProductPage"
             Title="Create product"
             BackgroundColor="Azure">
       
    <ScrollView>
           <VerticalStackLayout Padding="24" Spacing="20">
               
               <Border Stroke="#D1D5DB"
                       StrokeThickness="1"
                       BackgroundColor="White"
                       StrokeShape="RoundRectangle 16"
                       Padding="20"> 
                   
                   <VerticalStackLayout Spacing="20">
                       
                       <Grid ColumnDefinitions="*,*,*"
                             ColumnSpacing="12">

                           <Button x:Name="SnackTabButton"
                                   Grid.Column="0"
                                   Text="Create Snacks"
                                   Clicked="OnSnackSelected"
                                   BackgroundColor="#E8F0FE"
                                   TextColor="#1F2937"
                                   CornerRadius="10"
                                   HeightRequest="48"
                                   BorderColor="#93C5FD"
                                   BorderWidth="1.5"/>

                           <Button x:Name="LiquidWithPctTabButton"
                                   Grid.Column="1"
                                   Text="Create Liquid with %"
                                   Clicked="OnLiquidWithPctSelected"
                                   BackgroundColor="White"
                                   TextColor="#1F2937"
                                   CornerRadius="10"
                                   HeightRequest="48"
                                   BorderColor="#D1D5DB"
                                   BorderWidth="1"/>

                           <Button x:Name="ConsumableTabButton"
                                   Grid.Column="2"
                                   Text="Create Consumables"
                                   Clicked="OnConsumableSelected"
                                   BackgroundColor="White"
                                   TextColor="#1F2937"
                                   CornerRadius="10"
                                   HeightRequest="48"
                                   BorderColor="#D1D5DB"
                                   BorderWidth="1"/>
                       </Grid>
                       
                       <VerticalStackLayout Spacing="14">
                           
                           <Label Text="Name"
                                  FontAttributes="Bold"
                                  TextColor="#374151"
                                  FontSize="14"/>

                           <Border Stroke="#D1D5DB"
                                   StrokeThickness="1"
                                   StrokeShape="RoundRectangle 8"
                                   BackgroundColor="White"
                                   Padding="12,4">
                               <Entry x:Name="NameEntry"
                                      Placeholder="Enter name"
                                      BackgroundColor="Transparent"
                                      TextColor="#111827"
                                      PlaceholderColor="#9CA3AF"/>
                               
                           </Border>
                           
                           <Grid ColumnDefinitions="*,*"
                                 ColumnSpacing="16">
                               
                               <VerticalStackLayout Grid.Column="0" Spacing="6">
                                   <Label Text="Cost Price"
                                          FontAttributes="Bold"
                                          TextColor="#374151"
                                          FontSize="14"/>
                                   <Border Stroke="#D1D5DB"
                                           StrokeThickness="1"
                                           StrokeShape="RoundRectangle 8"
                                           BackgroundColor="White"
                                           Padding="12,4">
                                       <Entry x:Name="CostPriceEntry"
                                              Placeholder="Enter cost price"
                                              Keyboard="Numeric"
                                              BackgroundColor="Transparent"
                                              TextColor="#111827"
                                              PlaceholderColor="#9CA3AF"/>
                                   </Border>
                               </VerticalStackLayout>
                               
                               <VerticalStackLayout Grid.Column="1" Spacing="6">
                                   <Label Text="Sales Price"
                                          FontAttributes="Bold"
                                          TextColor="#374151"
                                          FontSize="14"/>
                                   <Border Stroke="#D1D5DB"
                                           StrokeThickness="1"
                                           StrokeShape="RoundRectangle 8"
                                           BackgroundColor="White"
                                           Padding="12,4">
                                       <Entry x:Name="SalesPriceEntry"
                                              Placeholder="Enter sales price"
                                              Keyboard="Numeric"
                                              BackgroundColor="Transparent"
                                              TextColor="#111827"
                                              PlaceholderColor="#9CA3AF"/>
                                   </Border>
                               </VerticalStackLayout>
                               </Grid>
                           
                           <Label Text="Quantity"
                                  FontAttributes="Bold"
                                  TextColor="#374151"
                                  FontSize="14"/>

                           <Border Stroke="#D1D5DB"
                                   StrokeThickness="1"
                                   StrokeShape="RoundRectangle 8"
                                   BackgroundColor="White"
                                   Padding="12,4">
                               <Entry x:Name="StockQuantityEntry"
                                      Placeholder="Enter number of quantities"
                                      Keyboard="Numeric"
                                      BackgroundColor="Transparent"
                                      TextColor="#111827"
                                      PlaceholderColor="#9CA3AF"/>
                           </Border>

                           
                       </VerticalStackLayout>
                       
                       
                   </VerticalStackLayout>
               

           </VerticalStackLayout>
       </ScrollView>
</ContentPage>

