<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrontEnd.EditProductPopup">
    
    <StackLayout>
        <Label Text="Min stock:"
               FontAttributes="Bold"
               TextColor="#FFD3E6"
               FontSize="14" />
    
        <Entry x:Name="MinStockEntry"
               Placeholder="Enter minimum stock"
               Keyboard="Numeric"
               BackgroundColor="Transparent"
               TextColor="#F7F2F5"
               PlaceholderColor="#C98AA8" />

        <Label Text="Max stock:"
               FontAttributes="Bold"
               TextColor="#FFD3E6"
               FontSize="14" />

        <Entry x:Name="MaxStockEntry"
               Placeholder="Enter maximum stock"
               Keyboard="Numeric"
               BackgroundColor="Transparent"
               TextColor="#F7F2F5"
               PlaceholderColor="#C98AA8" />
    </StackLayout>

</ContentView>
