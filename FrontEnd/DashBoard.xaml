<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrontEnd.DashBoard"
             Title="DashBoard"
             BackgroundColor="Azure">

    <Grid ColumnDefinitions="250,*" Padding="20" ColumnSpacing="20">

        <!-- VENSTRE: CollectionView -->
        <CollectionView Grid.Column="0"
                        ItemsSource="{Binding Products}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedProductDto}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="5"
                           BorderColor="#D1D5DB"
                           CornerRadius="10">
                        <Label Text="{Binding Name}" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- HØJRE: Info panel -->
        <VerticalStackLayout Grid.Column="1" Spacing="15">

            <Label Text="Selected product:" FontAttributes="Bold"/>
            <Entry Text="{Binding SelectedProductDto.Name}"
                   IsReadOnly="True"/>

            <Label Text="Quantity:" FontAttributes="Bold"/>
            <Entry Placeholder="Add quantity here"
                   Keyboard="Numeric"
                   Text="{Binding Quantity}" />

            <Button Text="Add quantity"
                    BackgroundColor="#E57373"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    Command="{Binding AddQuantityCommand}" />

        </VerticalStackLayout>

    </Grid>

</ContentPage>