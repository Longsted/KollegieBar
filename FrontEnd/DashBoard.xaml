<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrontEnd.DashBoard"
             Title="↑ Menu - Dashboard"
             BackgroundColor="#0F0F12"
             Shell.NavBarIsVisible="True">

    <Grid ColumnDefinitions="300, *" Padding="40" ColumnSpacing="40">

        <!-- LEFT SIDE (Product List + Filters) -->
        <Border Grid.Column="0"
                Stroke="#B84A84"
                StrokeThickness="1"
                BackgroundColor="#18181C"
                StrokeShape="RoundRectangle 16"
                Padding="10">

            <VerticalStackLayout Spacing="12">

                <!-- Filter / Sort row -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                    <Picker ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding SelectedCategory}"
                            Title="Category"
                            TextColor="#FFD3E6" />

                    <Picker Grid.Column="1"
                            ItemsSource="{Binding SortOptions}"
                            SelectedItem="{Binding SelectedSortOption}"
                            Title="Sort by"
                            TextColor="#FFD3E6" />
                </Grid>

                <!-- Product list -->
                <CollectionView ItemsSource="{Binding Products}"
                                SelectionMode="Single"
                                SelectedItem="{Binding SelectedProduct, Mode=TwoWay}">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!-- Two columns: name on left, quantity on right -->
                            <Grid Padding="12" ColumnDefinitions="*, Auto" BackgroundColor="Transparent">

                                <Label Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontSize="16"
                                       TextColor="#FFD3E6"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Text="{Binding StockQuantity}"
                                       FontSize="14"
                                       TextColor="#C98AA8"
                                       VerticalOptions="Center"
                                       HorizontalOptions="End"
                                       Margin="12,0,0,0" />

                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup Name="CommonStates">

                                        <!-- Normal (explicitly reset unselected state) -->
                                        <VisualState Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="Transparent" />
                                            </VisualState.Setters>
                                        </VisualState>

                                        <!-- Selected style -->
                                        <VisualState Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="#FF4FA3" />
                                            </VisualState.Setters>
                                        </VisualState>

                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <!-- RIGHT SIDE (Details) -->
        <Border Grid.Column="1"
                Stroke="#B84A84"
                StrokeThickness="1"
                BackgroundColor="#18181C"
                StrokeShape="RoundRectangle 16"
                Padding="30">

            <Grid RowDefinitions="Auto, Auto, Auto"
                  ColumnDefinitions="200, *"
                  RowSpacing="25"
                  ColumnSpacing="20">

                <!-- Selected product -->
                <Label Grid.Row="0" Grid.Column="0"
                       Text="Selected product:"
                       TextColor="#FFD3E6"
                       FontSize="16"
                       VerticalOptions="Center" />

                <Border Grid.Row="0" Grid.Column="1"
                        Stroke="#B84A84"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        BackgroundColor="#111114"
                        Padding="10,4">

                    <Entry Text="{Binding SelectedProduct.Name}"
                           IsReadOnly="True"
                           BackgroundColor="Transparent"
                           TextColor="#F7F2F5"
                           FontSize="16"/>
                </Border>

                <!-- Quantity -->
                <Label Grid.Row="1" Grid.Column="0"
                       Text="Quantity:"
                       TextColor="#FFD3E6"
                       FontSize="16"
                       VerticalOptions="Center" />

                <Border Grid.Row="1" Grid.Column="1"
                        Stroke="#B84A84"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        BackgroundColor="#111114"
                        Padding="10,4">

                    <Entry Placeholder="Enter amount..."
                           PlaceholderColor="#C98AA8"
                           Keyboard="Numeric"
                           Text="{Binding Quantity, TargetNullValue=''}"
                           BackgroundColor="Transparent"
                           TextColor="#F7F2F5"
                           FontSize="16"/>
                </Border>

                <!-- Button -->
                <HorizontalStackLayout Grid.Row="2" Grid.Column="1"
                                     Spacing="15"
                                     VerticalOptions="Start">

                    <Button Grid.Row="2" Grid.Column="1"
                        Text="Add quantity"
                        BackgroundColor="#FF4FA3"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="55"
                        WidthRequest="200"
                        HorizontalOptions="Start"
                        BorderColor="#FF79C6"
                        BorderWidth="1.5"
                        FontAttributes="Bold"
                        Command="{Binding AddQuantityCommand}"/>

                    <Button Grid.Row="2" Grid.Column="2"
                        Text="Edit Product"
                        BackgroundColor="#FF4FA3"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="55"
                        WidthRequest="200"
                        HorizontalOptions="Start"
                        BorderColor="#FF79C6"
                        BorderWidth="1.5"
                        FontAttributes="Bold"
                        Command="{Binding EditProductCommand}"/>
                </HorizontalStackLayout>

            </Grid>
        </Border>

    </Grid>

</ContentPage>