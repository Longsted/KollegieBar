<?xml version="1.0" encoding="UTF-8"?>

<Shell
    x:Class="FrontEnd.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FrontEnd"
    Title=""
    FlyoutBehavior="Flyout"
    FlyoutIcon="{Null}">
    
    <Shell.FlyoutHeader>
        <Grid HeightRequest="100" BackgroundColor="Black">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                <Image Source="dambaren_blacked.png" HeightRequest="100" Aspect="AspectFit"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>
    
    <FlyoutItem Title="Dashboard" x:Name="DashboardItem">
        <ShellContent ContentTemplate="{DataTemplate local:DashBoard}" />
    </FlyoutItem>

    <FlyoutItem Title="Create Product" x:Name="CreateProductItem">
        <ShellContent ContentTemplate="{DataTemplate local:CreateProductPage}" />
    </FlyoutItem>
    
    <FlyoutItem Title="Bar Overview" Route="BarOverview">
        <ShellContent ContentTemplate="{DataTemplate local:BarOverview}" />
    </FlyoutItem>
    <FlyoutItem Title="Statistics">
        <ShellContent ContentTemplate="{DataTemplate local:StatisticsPage}" />
    </FlyoutItem>

</Shell>
